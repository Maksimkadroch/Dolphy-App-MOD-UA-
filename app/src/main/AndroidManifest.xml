            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/retro"
            android:roundIcon="@drawable/retro"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityPhoto1"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/photo_icon_1"
            android:roundIcon="@drawable/photo_icon_1"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
