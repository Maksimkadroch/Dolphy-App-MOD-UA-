            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityPhoto2"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/photo_icon_2"
            android:roundIcon="@drawable/photo_icon_2"
            android:label="@string/app_name"
